# Supabase (opcional — sin esto usa localStorage)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Calendar + Login (OAuth client ID de Google Cloud Console)
# Requiere: API de Google Calendar habilitada + credenciales OAuth 2.0
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Email autorizado para acceder a la app (solo este puede iniciar sesión)
VITE_ALLOWED_EMAIL=tu@gmail.com

# ── Secrets de Supabase Edge Functions ───────────────────────────────────────
# Estas variables NO van en el frontend; se configuran en Supabase
# (Dashboard → Project Settings → Edge Functions → Secrets, o
#  `supabase secrets set GOOGLE_CLIENT_ID=... GOOGLE_CLIENT_SECRET=...`).
#
# GOOGLE_CLIENT_ID=<mismo client ID, sin prefijo VITE_>
# GOOGLE_CLIENT_SECRET=<client secret del OAuth client de Google Cloud>
