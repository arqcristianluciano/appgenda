# Firebase (obligatorio — la app usa Firestore + Auth + Functions + Storage)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=appgenda-rd-ad765.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=appgenda-rd-ad765
VITE_FIREBASE_STORAGE_BUCKET=appgenda-rd-ad765.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=...
VITE_FIREBASE_APP_ID=1:...:web:...

# Notificaciones push (OPCIONAL — recordatorios con la app cerrada vía FCM)
# Clave "Web Push certificate" (par de claves VAPID) de la consola de Firebase:
# Project settings → Cloud Messaging → Web configuration → Generate key pair.
# Sin esto, la app usa solo notificaciones locales (app abierta).
VITE_FIREBASE_VAPID_KEY=B...

# Google Calendar + Login (OAuth client ID de Google Cloud Console)
# OPCIONAL / fallback: las credenciales OAuth ahora se configuran DENTRO de la app
# (Ajustes de calendario → "Configurar Google"), que las guarda en Firestore. El
# client_id y el client_secret se cargan ahí; no hace falta rebuild ni secrets de
# Functions. Esta variable solo se usa como fallback del client_id si no hay config
# en runtime. Requiere: API de Google Calendar habilitada + credenciales OAuth 2.0.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com


# Sentry (opcional — para reporte de errores en producción)
# Crear el proyecto en https://cristian-apps.sentry.io/projects/appgenda/
VITE_SENTRY_DSN=https://xxxx@oxxxx.ingest.us.sentry.io/xxxx
