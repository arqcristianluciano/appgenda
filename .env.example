# Supabase (opcional — sin esto usa localStorage)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Calendar + Login (OAuth client ID de Google Cloud Console)
# Requiere: API de Google Calendar habilitada + credenciales OAuth 2.0
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google Client Secret — SOLO SERVIDOR (Vercel), nunca en el frontend
# Necesario para refresh automático de tokens sin popup.
# Obtener en: Google Cloud Console → APIs & Services → Credenciales → tu OAuth 2.0 Client
GOOGLE_CLIENT_SECRET=your-client-secret

# Email autorizado para acceder a la app (solo este puede iniciar sesión)
VITE_ALLOWED_EMAIL=tu@gmail.com
