rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function isOwner(resource) {
      return signedIn() && resource.data.ownerUid == uid();
    }
    function isTeamMember(teamId) {
      return signedIn() && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(uid()));
    }
    function isTeamAdmin(teamId) {
      return signedIn() &&
        get(/databases/$(database)/documents/teams/$(teamId)/members/$(uid())).data.role == 'admin';
    }
    function ownerOrTeam(resource) {
      return isOwner(resource) ||
        (resource.data.teamId != null && isTeamMember(resource.data.teamId));
    }
    function createOwnerOrTeam(data) {
      return signedIn() && data.ownerUid == uid() &&
        (data.teamId == null || isTeamMember(data.teamId));
    }

    // Public profiles: users can read all (for invite search), only write own
    match /profiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && userId == uid();
    }

    // Teams + nested members subcollection
    match /teams/{teamId} {
      allow read: if isTeamMember(teamId);
      allow create: if signedIn() && request.resource.data.createdBy == uid();
      allow update, delete: if isTeamAdmin(teamId);

      match /members/{memberId} {
        allow read: if signedIn() && (memberId == uid() || isTeamMember(teamId));
        allow create: if isTeamAdmin(teamId)
          || (memberId == uid() && get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy == uid());
        allow update, delete: if isTeamAdmin(teamId);
      }
    }

    // Owner-scoped data with optional team sharing
    match /tasks/{id} {
      allow read: if ownerOrTeam(resource);
      allow create: if createOwnerOrTeam(request.resource.data);
      allow update, delete: if ownerOrTeam(resource);
    }
    match /events/{id} {
      allow read: if ownerOrTeam(resource);
      allow create: if createOwnerOrTeam(request.resource.data);
      allow update, delete: if ownerOrTeam(resource);
    }
    match /projects/{id} {
      allow read: if ownerOrTeam(resource);
      allow create: if createOwnerOrTeam(request.resource.data);
      allow update, delete: if ownerOrTeam(resource);
    }
    match /obligations/{id} {
      allow read: if ownerOrTeam(resource);
      allow create: if createOwnerOrTeam(request.resource.data);
      allow update, delete: if ownerOrTeam(resource);
    }
    match /payments/{id} {
      // payments inherit access via their obligation; for simplicity, owner-only
      allow read, write: if isOwner(resource) ||
        (request.resource != null && request.resource.data.ownerUid == uid());
    }
    match /investments/{id} {
      allow read: if ownerOrTeam(resource);
      allow create: if createOwnerOrTeam(request.resource.data);
      allow update, delete: if ownerOrTeam(resource);
    }
    match /bank_accounts/{id} {
      allow read: if ownerOrTeam(resource);
      allow create: if createOwnerOrTeam(request.resource.data);
      allow update, delete: if ownerOrTeam(resource);
    }
    match /contacts/{id} {
      allow read: if ownerOrTeam(resource);
      allow create: if createOwnerOrTeam(request.resource.data);
      allow update, delete: if ownerOrTeam(resource);
    }
    match /remote_accesses/{id} {
      allow read: if ownerOrTeam(resource);
      allow create: if createOwnerOrTeam(request.resource.data);
      allow update, delete: if ownerOrTeam(resource);
    }

    // Per-user calendar config (id = uid)
    match /calendar_configs/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }

    // Per-user encrypted google refresh tokens (id = uid)
    match /google_tokens/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }

    // Per-user key-value localStorage backup (id = uid)
    match /user_storage/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }
  }
}
