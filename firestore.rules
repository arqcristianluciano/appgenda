rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function isTeamMember(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(uid()));
    }
    function isTeamAdmin(teamId) {
      return isTeamMember(teamId)
        && get(/databases/$(database)/documents/teams/$(teamId)/members/$(uid())).data.role == 'admin';
    }
    // Un doc es accesible por el usuario actual si es su dueño, o si su lista
    // `memberUids` lo incluye. Los docs owner-only existentes pasan por el branch
    // de ownerUid, así que cerrar la fuga no requiere migración.
    // NOTA: sin el guard `memberUids is list`. Ese guard hacía que Firestore
    // DENEGARA la query `where('memberUids','array-contains',uid)` (verificado en
    // el emulator), rompiendo el sharing por list-query. Si memberUids falta o no
    // es lista, `in` da error de evaluación → deny igual, así que es seguro.
    function ownsOrShared() {
      return resource.data.ownerUid == uid()
        || uid() in resource.data.memberUids;
    }

    // Profiles: legibles por cualquier usuario autenticado (necesario para la
    // búsqueda de invitados por email); escribibles solo al propio perfil.
    match /profiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && userId == uid();
    }

    // Teams + members — acotados a la membresía real.
    match /teams/{teamId} {
      allow read: if isTeamMember(teamId);
      allow create: if signedIn() && request.resource.data.createdBy == uid();
      allow update, delete: if isTeamAdmin(teamId);

      match /members/{memberId} {
        allow read: if isTeamMember(teamId);
        // Los admins gestionan miembros; el creador puede auto-agregarse al crear.
        allow create: if isTeamAdmin(teamId)
          || (memberId == uid()
              && get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy == uid());
        allow update, delete: if isTeamAdmin(teamId);
      }
    }

    // La query collectionGroup `where('userId','==',uid)` solo matchea la regla
    // recursiva con wildcard (la regla anidada de members no aplica a
    // collectionGroup). Se filtra por el campo userId (no por el id del doc, que
    // no se liga de forma fiable en queries collectionGroup) para acotar la
    // lectura a las membresías del propio usuario.
    match /{path=**}/members/{memberId} {
      allow read: if signedIn() && resource.data.userId == uid();
    }

    // Datos owner-scoped. Lectura: dueño o miembro compartido. Escritura: solo dueño.
    match /tasks/{id} {
      allow read: if signedIn() && (resource == null || ownsOrShared());
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /events/{id} {
      allow read: if signedIn() && (resource == null || ownsOrShared());
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /projects/{id} {
      allow read: if signedIn() && (resource == null || ownsOrShared());
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /obligations/{id} {
      allow read: if signedIn() && (resource == null || ownsOrShared());
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /payments/{id} {
      allow read: if signedIn() && (resource == null || ownsOrShared());
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /investments/{id} {
      allow read: if signedIn() && (resource == null || ownsOrShared());
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /bank_accounts/{id} {
      allow read: if signedIn() && (resource == null || ownsOrShared());
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /contacts/{id} {
      allow read: if signedIn() && (resource == null || ownsOrShared());
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /remote_accesses/{id} {
      allow read: if signedIn() && (resource == null || ownsOrShared());
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }

    // Per-user calendar config (id = uid)
    match /calendar_configs/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }

    // Per-user encrypted google refresh tokens (id = uid)
    match /google_tokens/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }

    // Per-user key-value localStorage backup (id = uid)
    match /user_storage/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }

    // Config OAuth de Google a nivel app.
    // - clientId: público por diseño (lo usa el frontend para el popup) → legible
    //   por cualquier usuario autenticado, pero NO escribible (solo vía callable).
    // - clientSecret: sensible → ni lectura ni escritura desde el cliente. Solo el
    //   admin SDK de las Cloud Functions lo lee/escribe (vía setgoogleoauthconfig).
    match /app_config/google_oauth_public {
      allow read: if signedIn();
      allow write: if false;
    }
    match /app_config/google_oauth_secret {
      allow read, write: if false;
    }

    // Tokens de notificaciones push por usuario (id = uid). El usuario gestiona
    // los suyos; las Cloud Functions (admin SDK) los leen para enviar y limpian
    // los inválidos.
    match /push_tokens/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }

    // Registro de recordatorios ya enviados (dedup). Solo el admin SDK lo toca.
    match /sent_reminders/{docId} {
      allow read, write: if false;
    }
  }
}
