rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }

    // Profiles: readable by any signed-in user (for invite search), writable only to own
    match /profiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && userId == uid();
    }

    // Teams + members
    match /teams/{teamId} {
      allow read: if signedIn();
      allow write: if signedIn();

      match /members/{memberId} {
        allow read, write: if signedIn();
      }
    }

    // Owner-scoped data: any signed-in user can read all docs that have
    // ownerUid == uid OR teamId set; writes require ownerUid stamp.
    match /tasks/{id} {
      allow read: if signedIn() && (resource == null || resource.data.ownerUid == uid() || resource.data.teamId != null);
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /events/{id} {
      allow read: if signedIn() && (resource == null || resource.data.ownerUid == uid() || resource.data.teamId != null);
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /projects/{id} {
      allow read: if signedIn() && (resource == null || resource.data.ownerUid == uid() || resource.data.teamId != null);
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /obligations/{id} {
      allow read: if signedIn() && (resource == null || resource.data.ownerUid == uid() || resource.data.teamId != null);
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /payments/{id} {
      allow read: if signedIn();
      allow write: if signedIn();
    }
    match /investments/{id} {
      allow read: if signedIn() && (resource == null || resource.data.ownerUid == uid() || resource.data.teamId != null);
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /bank_accounts/{id} {
      allow read: if signedIn() && (resource == null || resource.data.ownerUid == uid() || resource.data.teamId != null);
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /contacts/{id} {
      allow read: if signedIn() && (resource == null || resource.data.ownerUid == uid() || resource.data.teamId != null);
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }
    match /remote_accesses/{id} {
      allow read: if signedIn() && (resource == null || resource.data.ownerUid == uid() || resource.data.teamId != null);
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if signedIn() && resource.data.ownerUid == uid();
    }

    // Per-user calendar config (id = uid)
    match /calendar_configs/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }

    // Per-user encrypted google refresh tokens (id = uid)
    match /google_tokens/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }

    // Per-user key-value localStorage backup (id = uid)
    match /user_storage/{userId} {
      allow read, write: if signedIn() && userId == uid();
    }
  }
}
