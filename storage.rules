rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // project-files/{ownerUid}/{projectId}/{file} — solo el dueño (uid en la ruta).
    // El uid va EN la ruta porque las reglas de Storage no pueden consultar Firestore
    // para verificar propiedad. Compartir sigue funcionando: la downloadURL que se
    // guarda en el doc lleva token y no pasa por estas reglas.
    match /project-files/{ownerUid}/{projectId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == ownerUid;
      allow write: if request.auth != null && request.auth.uid == ownerUid
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
